    {
      "parameters": {
        "jsCode": "const events = $input.all()[0].json.weeklyevents.event;\nconst targetEvents = ['Unemployment Rate', 'Non-Farm Employment Change', 'CPI m/m'];\n\nlet scheduledItems = [];\n// 捕捉服务器当前时间，作为对比基准\nconst now = new Date(); \n\nfor (let e of events) {\n  // 只要符合条件，不管是周几的统统拿下\n  if (e.country === \"USD\" && e.impact === \"High\" && e.title && targetEvents.includes(e.title)) {\n    let timeStr = e.time.trim().toLowerCase();\n    \n    if (timeStr.includes('all') || timeStr.includes('tentative')) continue;\n\n    let isPM = timeStr.includes('pm');\n    let [hours, mins] = timeStr.replace(/[a-z]/g, '').split(':');\n    hours = parseInt(hours);\n    mins = parseInt(mins);\n\n    if (isPM && hours !== 12) hours += 12;\n    if (!isPM && hours === 12) hours = 0;\n    \n    let dateParts = e.date.split('-');\n    let month = parseInt(dateParts[0]) - 1; \n    let day = parseInt(dateParts[1]);\n    let year = parseInt(dateParts[2]);\n\n    let releaseDateUTC = new Date(Date.UTC(year, month, day, hours, mins, 0));\n    let waitTime = new Date(releaseDateUTC.getTime() + 5 * 60000);\n    \n    // 【架构升级】：判断这个事件是不是已经成为历史了？\n    let isPast = waitTime.getTime() < now.getTime();\n    \n    scheduledItems.push({\n      json: {\n        title: e.title,\n        original_gmt_time: e.time,\n        forecast_value: e.forecast || \"N/A\",\n        previous_value: e.previous || \"N/A\",\n        resume_time: waitTime.toISOString(),\n        is_past: isPast, // 返回 true 或 false\n        url: e.url,\n        actual_value: null\n      }\n    });\n  }\n}\n\nreturn scheduledItems;"
      },
