    {
      "parameters": {
        "jsCode": "// 1. 关键第一步：知道我们在找谁？\n// 我们跨节点回到最初的起点，拿到【当前正在被处理】的那个事件的 Title\n// (注意：如果你的节点不叫这个名字，请把括号里的名字换成你画布上的实际名字)\nconst targetTitle = $('Calculate Release Time').item.json.title;\n\n// 2. 拿到刚刚从 FRED 抓回来的最新实际值\nconst fredActual = $('Fetch new FRED API').first().json.observations[0].value;\n\n// 3. 拿到你从文件里读取进来的完整事件列表 (包含了本周所有的 data)\nconst allEventsFromFile = $input.all();\n\n// 4. 执行“查找并更新”的魔法\n// 我们遍历文件里的每一个事件，看谁的 title 对得上\nconst updatedEvents = allEventsFromFile.map(element => {\n  // 提取出里面的 data 核心内容\n  let eventData = element.json.data;\n\n  // 如果这个事件的 title，刚好等于我们当前正在跑的 title\n  if (eventData.title === targetTitle) {\n    // 找到了！只给它一个人更新 FRED 数据\n    eventData.is_past = true;\n    eventData.actual_value = fredActual;\n  }\n\n  // 无论有没有更新，都把它按原来的结构拼回去\n  return {\n    json: {\n      data: eventData\n    }\n  };\n});\n\n// 5. 返回更新后的完整列表！\n// 现在你可以直接把这个返回结果，连到你的 Upload data 节点去覆盖旧文件了\nreturn updatedEvents;"
      },
