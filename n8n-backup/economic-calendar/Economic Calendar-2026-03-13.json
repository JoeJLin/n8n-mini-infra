    {
      "parameters": {
        "jsCode": "// 华尔街核心指标字典\nconst dict = {\n  \"Non-Farm Employment Change\": { id: \"PAYEMS\", units: \"chg\" },\n  \"Unemployment Rate\":          { id: \"UNRATE\", units: \"lin\" }, // lin 代表保持原样\n  \"Unemployment Claims\":        { id: \"ICSA\", units: \"lin\" },\n  \"CPI m/m\":                    { id: \"CPIAUCSL\", units: \"pch\" },\n  \"CPI y/y\":                    { id: \"CPIAUCSL\", units: \"pc1\" },\n  \"Core CPI m/m\":               { id: \"CPILFESL\", units: \"pch\" },\n  \"PCE Price Index m/m\":        { id: \"PCEPI\", units: \"pch\" },\n  \"Core PCE Price Index m/m\":   { id: \"PCEPILFE\", units: \"pch\" },\n  \"Advance GDP q/q\":            { id: \"GDP\", units: \"pca\" },\n  \"Prelim GDP q/q\":             { id: \"GDP\", units: \"pca\" },\n  \"Final GDP q/q\":              { id: \"GDP\", units: \"pca\" },\n  \"Retail Sales m/m\":           { id: \"RSAFS\", units: \"pch\" },\n  \"Federal Funds Rate\":         { id: \"FEDFUNDS\", units: \"lin\" }\n};\n\n// 拿到从上一个节点传过来的事件名字\nconst eventTitle = $('Calculate Release Time').first().json.title;\n\n// 去字典里查一下\nconst target = dict[eventTitle];\n\n// 如果查不到（说明是不重要的数据），直接返回空数组，流程在这里安静停止\nif (!target) {\n  return []; \n}\n\n// 如果查到了，把 ID 和单位附加到数据里，传给下一个 HTTP 节点\nreturn {\n  json: {\n    ...$input.all()[0].json, // 保留原来的标题、预期值等\n    target_series_id: target.id,\n    target_units: target.units\n  }\n};"
      },
