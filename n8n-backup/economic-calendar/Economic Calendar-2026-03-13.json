      "id": "23eee8cc-6868-4076-84db-0128cf27e5d6",
      "name": "Extract from File1"
    },
    {
      "parameters": {
        "jsCode": "// 1. 跨节点召唤：拿到刚刚新鲜计算出来的本周日历（全都是 null）\nconst newEvents = $('Calculate Release Time').all();\n\n// 2. 当前节点输入：拿到从云端下载回来的旧日历（里面可能保留着昨天的 actual_value）\n// 注意：如果是本周第一次跑，可能还没有旧文件，所以我们做一个容错处理\nlet oldEvents = [];\nif ($input.all()[0] && $input.all()[0].json) {\n  // 如果旧文件存在且不是空的\n  oldEvents = $input.all().map(item => item.json);\n}\n\nlet mergedEvents = [];\n\n// 3. 核心合并逻辑：遍历每一个新事件\nfor (let newEvt of newEvents) {\n  let newData = newEvt.json; // 提取新数据的 json 核心\n\n  // 在旧数据大军中，寻找有没有“同名”且“时间完全一样”的旧兄弟？\n  let foundOld = oldEvents.find(oldEvt => \n    oldEvt.title === newData.title && \n    oldEvt.resume_time === newData.resume_time\n  );\n\n  // 💥 魔法在这里：如果找到了这位旧兄弟，而且它身上已经有了实际值\n  if (foundOld && foundOld.actual_value !== null) {\n    // 把旧兄弟的 actual_value 继承过来！绝不让它被 null 覆盖！\n    newData.actual_value = foundOld.actual_value;\n  }\n\n  // 把处理好的完美数据装进新数组\n  mergedEvents.push({ json: newData });\n}\n\n// 4. 输出最终的完美日历数组，交给下一个节点去 Upload 覆盖云端文件！\nreturn mergedEvents;"
      },
